# Runtime connection: templeos_app role (NOBYPASSRLS) — RLS enforced on every query.
# Create the role with: APP_DB_PASSWORD=... pnpm --filter @templeos/db exec node scripts/create-app-role.mjs
DATABASE_URL=postgresql://templeos_app.<project-ref>:<app-role-password>@<region>.pooler.supabase.com:5432/postgres

# Admin connection: postgres role (BYPASSRLS) — migrations and role setup ONLY, never the app
DATABASE_URL_ADMIN=postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:5432/postgres

# Supabase — client keys (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key> # server-only; migrations and audited cross-tenant jobs

# Tenant site resolution
NEXT_PUBLIC_ROOT_DOMAIN=localhost # templeos.com in production

# Email
RESEND_API_KEY=

# Payments (Phase 1)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
