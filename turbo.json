{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL*", "NEXT_PUBLIC_*", "SUPABASE_*", "APP_DB_PASSWORD", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
